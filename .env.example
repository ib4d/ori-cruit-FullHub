# ============================================================
# ORI-CRUIT FullHub — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Variables prefixed with VITE_ are exposed to the frontend.
# ============================================================

# --- Frontend (Vite) ---
# Base URL for the backend API (used by frontend fetch calls)
VITE_API_URL=http://localhost:3000/api

# --- Backend (NestJS) — future ---
# Node environment: development | production | test
NODE_ENV=development

# Port for the NestJS API server
PORT=3000

# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/oricruit?schema=public

# JWT secret for authentication token signing (use a strong random string)
JWT_SECRET=change-me-to-a-strong-random-secret

# JWT token expiration (e.g., 7d, 24h, 3600s)
JWT_EXPIRATION=7d

# --- HRappka Integration — future ---
# HRappka API endpoint and credentials
HRAPPKA_API_URL=https://api.hrappka.pl
HRAPPKA_API_KEY=

# --- Google Sheets Integration — future ---
# Google OAuth credentials for Sheets sync
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEETS_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- File Storage (S3-compatible) — future ---
# For candidate document uploads and media storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=oricruit-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# --- OCR Service — future ---
# Optional external OCR API (if not using Tesseract.js locally)
OCR_API_URL=
OCR_API_KEY=
